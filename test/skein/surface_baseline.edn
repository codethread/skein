 :queries
 {"feature-active"
  {:params [:feature], :where [:and [:= :state "active"] [:= [:attr :feature] [:param :feature]]]},
  "feature-work"
  {:params [:feature],
   :where
   [:and
    [:= :state "active"]
    [:= [:attr :feature] [:param :feature]]
    [:in [:attr :kind] ["task" "review"]]]},
  "feature-owner-work"
  {:params [:feature :owner],
   :where
   [:and
    [:= :state "active"]
    [:= [:attr :feature] [:param :feature]]
    [:= [:attr :owner] [:param :owner]]
    [:in [:attr :kind] ["task" "review"]]]},
  "feature-run"
  {:params [:feature], :where [:and [:= :state "active"] [:= [:attr "workflow/run-id"] [:param :feature]]]},
  "workflow-runs" [:and [:= :state "active"] [:= [:attr "workflow/role"] "molecule"]],
  "devflow-runs"
  [:and
   [:= :state "active"]
   [:= [:attr "workflow/role"] "molecule"]
   [:= [:attr "workflow/family"] "devflow"]],
  "work"
  [:and
   [:= :state "active"]
   [:or [:missing [:attr "agent-run/run"]] [:not [:= [:attr "agent-run/run"] "true"]]]
   [:or [:missing [:attr "kanban/status"]] [:not [:= [:attr "kanban/status"] "refinement"]]]
   [:or
    [:missing [:attr "workflow/role"]]
    [:not [:in [:attr "workflow/role"] ["molecule" "digest" "procedure"]]]]]}}
