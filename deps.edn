{:paths ["src" "spools/batteries/src" "dev"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        com.github.seancorfield/next.jdbc {:mvn/version "1.3.1048"}
        org.xerial/sqlite-jdbc {:mvn/version "3.53.2.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}
        org.clojure/tools.cli {:mvn/version "1.1.230"}
        nrepl/nrepl {:mvn/version "1.3.1"}
        org.slf4j/slf4j-nop {:mvn/version "1.7.36"}
        com.bhauman/rebel-readline {:mvn/version "0.1.11"}}
 :aliases
 {:test {:extra-paths ["test" "spools/workflow/src" "spools/ephemeral/src" "spools/roster/src" "spools/loom/src" "spools/carder/src" "spools/text-search/src" "spools/bobbin/src" "spools/guild/src" "spools/selvage/src" "spools/agent-run/src" "spools/delegation/src" "spools/chime/src" "spools/cron/src" "spools/bench/src"
                       ".skein/spools/macros/src"]
         ;; devflow is a git-distributed spool. Keep this sha exactly synchronized
         ;; with .skein/spools.edn: config_test loads .skein/config.clj in-process,
         ;; while the weaver consumes the spools.edn coordinate.
         :extra-deps {io.github.codethread/devflow.spool
                      {:git/url "https://github.com/codethread/devflow.spool.git"
                       :git/sha "e9b28f5db61820b28a1ac1b590cc87e70c835cac"}
                      ;; kanban is a git-distributed spool. Keep this sha exactly
                      ;; synchronized with .skein/spools.edn (config_test enforces
                      ;; the pairing): config_test loads .skein/config.clj
                      ;; in-process, while the weaver consumes the spools.edn
                      ;; coordinate.
                      io.github.codethread/kanban.spool
                      {:git/url "https://github.com/codethread/kanban.spool.git"
                       :git/sha "54eea43e3afc50c3f17335d297a74af8d6767704"}
                      ;; Test-only ergonomics: readable nested-map/JSON assertions
                      ;; (match?) and spec-driven property tests (defspec). Kept
                      ;; off the main src/weaver classpath.
                      nubank/matcher-combinators {:mvn/version "3.9.1"}
                      org.clojure/test.check {:mvn/version "1.1.1"}}
         :jvm-opts ["--enable-native-access=ALL-UNNAMED"]
         :main-opts ["-m" "skein.test-runner"]}
  ;; Per-worktree warm test REPL: compose with :test to inherit its classpath and
  ;; native-access opt — `clojure -M:test:test-repl` boots skein.test.warm.
  :test-repl {:main-opts ["-m" "skein.test.warm"]}
  :large-attr-bench {:extra-paths ["test" "spools/text-search/src"]
                     :jvm-opts ["--enable-native-access=ALL-UNNAMED"]
                     :main-opts ["-m" "skein.large-attr-benchmark"]}
  :repl {:jvm-opts ["--enable-native-access=ALL-UNNAMED"]}
  :rebel {:jvm-opts ["--enable-native-access=ALL-UNNAMED"]
          :main-opts ["-m" "rebel-readline.main"]}
  :skein {:jvm-opts ["--enable-native-access=ALL-UNNAMED"]}
  :smoke {:jvm-opts ["--enable-native-access=ALL-UNNAMED"]
          :main-opts ["-m" "skein.smoke"]}
  :format {:extra-deps {dev.weavejester/cljfmt {:mvn/version "0.13.1"}}
           :main-opts ["-m" "cljfmt.main" "check" "src" "spools/batteries/src" "spools/workflow/src" "spools/ephemeral/src" "spools/roster/src" "spools/loom/src" "spools/carder/src" "spools/text-search/src" "spools/bobbin/src" "spools/guild/src" "spools/selvage/src" "test" "dev" "scripts"
                       ".skein/init.clj" ".skein/config.clj" ".skein/workflows.clj" ".skein/harnesses.clj"
                       ".skein/attention.clj" ".skein/nvd_scan.clj" ".skein/reviewers.clj"]}
  :format/fix {:extra-deps {dev.weavejester/cljfmt {:mvn/version "0.13.1"}}
               :main-opts ["-m" "cljfmt.main" "fix" "src" "spools/batteries/src" "spools/workflow/src" "spools/ephemeral/src" "spools/roster/src" "spools/loom/src" "spools/carder/src" "spools/text-search/src" "spools/bobbin/src" "spools/guild/src" "spools/selvage/src" "test" "dev" "scripts"
                           ".skein/init.clj" ".skein/config.clj" ".skein/workflows.clj" ".skein/harnesses.clj"
                           ".skein/attention.clj" ".skein/nvd_scan.clj" ".skein/reviewers.clj"]}
  :lint/clj-kondo {:extra-deps {clj-kondo/clj-kondo {:mvn/version "2025.06.05"}}
                   :main-opts ["-m" "clj-kondo.main" "--lint" "src" "spools/batteries/src" "spools/workflow/src" "spools/ephemeral/src" "spools/roster/src" "spools/loom/src" "spools/carder/src" "spools/text-search/src" "spools/bobbin/src" "spools/guild/src" "spools/selvage/src" "test"]}
  :lint/splint {:extra-deps {io.github.noahtheduke/splint {:mvn/version "1.21.0"}}
                :main-opts ["-m" "noahtheduke.splint" "--output" "clj-kondo" "src" "spools/batteries/src" "spools/workflow/src" "spools/ephemeral/src" "spools/roster/src" "spools/loom/src" "spools/carder/src" "spools/text-search/src" "spools/bobbin/src" "spools/guild/src" "spools/selvage/src" "test"]}
  :reflect-check {:extra-paths ["scripts" "spools/workflow/src" "spools/ephemeral/src" "spools/roster/src" "spools/loom/src" "spools/carder/src" "spools/text-search/src" "spools/bobbin/src" "spools/guild/src" "spools/selvage/src" "spools/agent-run/src" "spools/delegation/src" "spools/chime/src" "spools/cron/src" "spools/bench/src"]
                  :jvm-opts ["--enable-native-access=ALL-UNNAMED" "-Dclojure.compiler.direct-linking=true"]
                  :main-opts ["-m" "quality.reflect-check"]}
  :deps/antq {:extra-deps {com.github.liquidz/antq {:mvn/version "2.11.1276"}}
              :main-opts ["-m" "antq.core"]}
  :security/clj-watson {:extra-deps {io.github.clj-holmes/clj-watson {:git/tag "v6.1.0" :git/sha "be98e4d"}}
                        :main-opts ["-m" "clj-watson.cli" "scan" "-p" "deps.edn" "-t" "github-advisory"]}
  :security/clj-watson-nvd {:extra-deps {io.github.clj-holmes/clj-watson {:git/tag "v6.1.0" :git/sha "be98e4d"}}
                            :main-opts ["-m" "clj-watson.cli" "scan" "-p" "deps.edn"]}}}
