#!/usr/bin/env python3
"""bench host engine: speaks the docker/podman CLI dialect the bench spool
emits, but executes the command directly on the host.

Supported calls (exactly what ct.spools.bench.exec emits):
  host-engine run --rm -i --name NAME -e K=V ... -v SRC:DST[:ro] ... -w DIR IMAGE CMD...
  host-engine image inspect --format {{.Id}} IMAGE
  host-engine kill NAME

Semantics:
- Container paths are rewritten to host paths via the -v mounts (longest
  prefix wins) in env values, the workdir, and every command token.
- ro file/dir mounts whose DST lands inside another mount (the auth mounts
  under /bench/home) are materialized as symlinks inside the rewritten tree.
- The command runs with a minimal env (PATH/TERM/TMPDIR from the host plus the
  rewritten -e set, so HOME is the entry's home dir) and inherits
  stdin/stdout/stderr from the caller (bench owns redirection).
- The shim execs the command (same pid), so bench's process tracking,
  timeout destroy, and `kill NAME` (via the pidfile) all behave.

This trades the container's isolation for zero-image smoke runs: determinism
still comes from the pinned clone + controlled HOME, but the host toolchain
leaks in. Good for smoke tests and harness comparisons; not for archival runs.
"""

import json
import os
import signal
import sys

PID_DIR = os.path.join(os.environ.get("TMPDIR", "/tmp"), "bench-host-engine")


def die(msg):
    print("host-engine: " + msg, file=sys.stderr)
    sys.exit(125)


def rewrite(s, mounts):
    for cont, src in sorted(mounts.items(), key=lambda kv: -len(kv[0])):
        s = s.replace(cont, src)
    return s


def cmd_image(args):
    # image inspect --format {{.Id}} IMAGE -> stable fake digest
    if len(args) >= 1 and args[0] == "inspect":
        image = args[-1]
        print("host-engine:" + image)
        sys.exit(0)
    die("unsupported image subcommand: %r" % (args,))


def cmd_kill(args):
    if not args:
        die("kill: missing container name")
    pidfile = os.path.join(PID_DIR, args[0] + ".pid")
    try:
        with open(pidfile) as f:
            pid = int(f.read().strip())
        os.kill(pid, signal.SIGKILL)
    except (FileNotFoundError, ValueError, ProcessLookupError):
        sys.exit(1)
    sys.exit(0)


def cmd_run(args):
    name = None
    env_pairs = []
    mounts = {}   # container path -> host path (rw order-independent)
    ro_mounts = []  # (host, container)
    workdir = None
    i = 0
    while i < len(args):
        a = args[i]
        if a in ("--rm", "-i"):
            i += 1
        elif a == "--name":
            name = args[i + 1]
            i += 2
        elif a == "-e":
            env_pairs.append(args[i + 1])
            i += 2
        elif a == "-v":
            spec = args[i + 1]
            parts = spec.split(":")
            if len(parts) == 3 and parts[2] == "ro":
                ro_mounts.append((parts[0], parts[1]))
            elif len(parts) == 2:
                mounts[parts[1]] = parts[0]
            else:
                die("unsupported -v spec: " + spec)
            i += 2
        elif a == "-w":
            workdir = args[i + 1]
            i += 2
        else:
            break  # IMAGE
    if i >= len(args):
        die("run: no image given")
    # image token is ignored beyond this point
    cmd = args[i + 1:]
    if not cmd:
        die("run: no command given")
    if not name or not workdir:
        die("run: --name and -w are required")

    # Materialize ro mounts as symlinks inside the rewritten tree.
    for host_src, cont_dst in ro_mounts:
        target = rewrite(cont_dst, mounts)
        if target == cont_dst:
            die("ro mount dst outside known mounts: " + cont_dst)
        os.makedirs(os.path.dirname(target), exist_ok=True)
        if os.path.lexists(target):
            os.remove(target)
        os.symlink(host_src, target)

    env = {}
    for k in ("PATH", "TERM", "TMPDIR"):
        if k in os.environ:
            env[k] = os.environ[k]
    for pair in env_pairs:
        k, _, v = pair.partition("=")
        env[k] = rewrite(v, mounts)
    cwd = rewrite(workdir, mounts)
    argv = [rewrite(t, mounts) for t in cmd]

    os.makedirs(PID_DIR, exist_ok=True)
    with open(os.path.join(PID_DIR, name + ".pid"), "w") as f:
        f.write(str(os.getpid()))
    try:
        os.chdir(cwd)
    except FileNotFoundError:
        die("run: workdir does not exist: " + cwd)
    try:
        os.execvpe(argv[0], argv, env)
    except FileNotFoundError:
        die("run: command not found: " + argv[0])


def main():
    if len(sys.argv) < 2:
        die("no subcommand")
    sub, rest = sys.argv[1], sys.argv[2:]
    if sub == "run":
        cmd_run(rest)
    elif sub == "image":
        cmd_image(rest)
    elif sub == "kill":
        cmd_kill(rest)
    else:
        die("unsupported subcommand: " + sub)


if __name__ == "__main__":
    main()
