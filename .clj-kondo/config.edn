{;; with-weaver-world binds [ctx opts] and with-runtimes binds [sym val ...] as
 ;; let-shaped vectors; kondo cannot expand these custom macros, so lint their
 ;; binding forms as let to resolve the bound symbols.
 :lint-as {clojure.test.check.clojure-test/defspec clojure.test/deftest
           skein.test.alpha/with-weaver-world clojure.core/let
           skein.userland-test/with-runtimes clojure.core/let}
 :hooks {:analyze-call {clojure.core/ns hooks.project-rules/ns-docstring
                        ns hooks.project-rules/ns-docstring
                        clojure.core/def hooks.project-rules/no-spool-module-atom
                        def hooks.project-rules/no-spool-module-atom
                        clojure.core/defonce hooks.project-rules/no-spool-module-atom
                        defonce hooks.project-rules/no-spool-module-atom
                        clojure.core/let hooks.project-rules/no-fn-keys-destructure
                        let hooks.project-rules/no-fn-keys-destructure
                        clojure.core/fn hooks.project-rules/no-fn-keys-destructure
                        fn hooks.project-rules/no-fn-keys-destructure
                        clojure.core/defn hooks.project-rules/no-fn-keys-destructure
                        defn hooks.project-rules/no-fn-keys-destructure
                        skein.macros.queries/defquery hooks.project-rules/defquery
                        skein.macros.queries/defq hooks.project-rules/defquery
                        skein.macros.ops/defop hooks.project-rules/defop}}
 :linters {:project/ns-docstring {:level :error}
           :project/no-spool-module-atom {:level :error}
           :project/no-fn-keys-destructure {:level :error}
           ;; These test-local private vars are workflow constructors and chime
           ;; rule handlers referenced only by fully-qualified quoted symbol
           ;; (register-workflow!/defrule!), which kondo cannot track — they are
           ;; used, not dead.
           :unused-private-var
           {:exclude [skein.spools.workflow-test/toastie-serve-workflow
                      skein.spools.workflow-test/pr-fix-ci-workflow
                      skein.spools.workflow-test/pr-review-round-workflow
                      skein.spools.workflow-test/pr-fix-and-push-workflow
                      skein.spools.workflow-test/pr-merge-workflow
                      skein.spools.workflow-test/empty-continuation-workflow
                      skein.spools.workflow-test/routed-continuation-workflow
                      skein.spools.workflow-test/loopy-revision-workflow
                      skein.spools.workflow-test/registry-second-stage
                      skein.spools.workflow-test/registry-alt-second-stage
                      skein.spools.workflow-test/downstream-stage-workflow
                      skein.spools.workflow-test/introspect-stage-b-workflow
                      skein.chime-test/throwing-rule
                      skein.chime-test/invalid-notification-rule]}}}
