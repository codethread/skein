#!/usr/bin/env bash
# ralph — foreground epic loop: repeatedly hand an epic to a fresh headless
# claude run until the epic strand is closed or the agent pulls the brake.
#
# Each iteration re-invokes `claude --print` with the user's prompt plus a
# harness addendum covering the two loop exits: the agent must close the epic
# (`strand update <epic> --state closed`) when every feature under it is
# complete, and may emit the exact marker `RALPH-STOP: <reason>` as its final
# line to halt the loop on a blocker it cannot work around. The loop itself
# only ever reads state; all mutation happens inside the agent runs.
#
# This is deliberately a watchable foreground script, not a background strand
# command: stream-json output is rendered live so a human can see every
# assistant message and tool call as it happens. Raw transcripts land under
# $RALPH_LOG_DIR for post-hoc reading.
#
# Usage: scripts/ralph <epic-id> "<prompt>" [-- <extra claude args>]
#
# Environment:
#   RALPH_MODEL           model for each run (default: fable)
#   RALPH_EFFORT          effort level (default: high)
#   RALPH_MAX_ITERATIONS  safety cap; 0 means unlimited (default: 30)
#   RALPH_SKIP_PERMISSIONS  set to 0 to drop --dangerously-skip-permissions
#                           (default on: headless runs cannot answer prompts)
#   RALPH_LOG_DIR         transcript dir (default: $TMPDIR/ralph/<epic>-<ts>)
set -euo pipefail

usage() {
  echo "usage: scripts/ralph <epic-id> \"<prompt>\" [-- <extra claude args>]" >&2
  exit 2
}

[ $# -ge 2 ] || usage
epic="$1"
prompt="$2"
shift 2
extra_args=()
if [ $# -gt 0 ]; then
  [ "$1" = "--" ] || usage
  shift
  extra_args=("$@")
fi

for dep in claude jq; do
  command -v "$dep" >/dev/null || { echo "ralph: $dep not found on PATH" >&2; exit 1; }
done

# Prefer the repo-local strand next to this script so ralph works from any cwd
# and never depends on a globally installed binary.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
strand="$script_dir/../bin/strand"
[ -x "$strand" ] || strand="strand"
command -v "$strand" >/dev/null || { echo "ralph: no strand binary (run make build)" >&2; exit 1; }

model="${RALPH_MODEL:-fable}"
effort="${RALPH_EFFORT:-high}"
max_iterations="${RALPH_MAX_ITERATIONS:-30}"
log_dir="${RALPH_LOG_DIR:-${TMPDIR:-/tmp}/ralph/${epic}-$(date +%Y%m%d-%H%M%S)}"
mkdir -p "$log_dir"

claude_flags=(--print --verbose --output-format stream-json --model "$model" --effort "$effort")
if [ "${RALPH_SKIP_PERMISSIONS:-1}" != "0" ]; then
  claude_flags+=(--dangerously-skip-permissions)
fi

# The strand lifecycle (active|closed|replaced) is the loop condition; anything
# other than active means the epic is finished and the loop is done.
epic_state() {
  "$strand" show "$epic" | jq -r '.state'
}

epic_json="$("$strand" show "$epic" 2>/dev/null)" \
  || { echo "ralph: epic $epic not found (strand show failed)" >&2; exit 1; }
epic_title="$(jq -r '.title' <<<"$epic_json")"
if [ "$(jq -r '.state' <<<"$epic_json")" != "active" ]; then
  echo "ralph: epic $epic ($epic_title) is already $(jq -r '.state' <<<"$epic_json"); nothing to do"
  exit 0
fi

harness_prompt() {
  cat <<EOF
$prompt

--- ralph harness (scripts/ralph, iteration $1) ---
You are one iteration of "ralph", a foreground loop driving epic $epic ("$epic_title").
Every iteration starts with fresh context: orient from live state first
(strand show $epic, strand kanban card $epic, strand kanban board), not from memory.
The loop re-invokes you until the epic strand is closed, so:
- CRITICAL: when every feature under the epic is complete, close the epic with
  \`strand update $epic --state closed\` — the loop runs forever otherwise.
- Leave the world resumable before you finish: notes on the doing task, work
  committed and pushed. The next iteration knows only what the strands say.
- EMERGENCY BRAKE: if you hit a blocker you cannot work around, end your reply
  with a final line of exactly: RALPH-STOP: <one-line reason>
  Use it only for hard blockers; it halts the loop immediately.
EOF
}

# Render the stream-json transcript live: assistant text verbatim, tool calls
# as one-line markers, and the closing result stats. Everything else (tool
# results, system events) stays in the raw log only.
render_stream() {
  jq --unbuffered -rj '
    if .type == "assistant" then
      [.message.content[]?
       | if .type == "text" then .text + "\n"
         elif .type == "tool_use" then "⏺ " + .name + " " + ((.input | tojson)[0:200]) + "\n"
         else empty end]
      | join("")
    elif .type == "result" then
      "\n[ralph] run finished: " + (.subtype // "?")
      + " | turns " + ((.num_turns // 0) | tostring)
      + " | $" + ((.total_cost_usd // 0) * 100 | round / 100 | tostring)
      + " | " + (((.duration_ms // 0) / 60000 * 10 | round / 10 | tostring)) + "min\n"
    else empty end'
}

iteration=0
consecutive_failures=0
while true; do
  state="$(epic_state)" || { echo "[ralph] cannot read epic state (weaver down?); stopping" >&2; exit 1; }
  if [ "$state" != "active" ]; then
    echo "[ralph] epic $epic is $state — loop complete after $iteration iteration(s)"
    exit 0
  fi
  if [ "$max_iterations" -ne 0 ] && [ "$iteration" -ge "$max_iterations" ]; then
    echo "[ralph] hit RALPH_MAX_ITERATIONS=$max_iterations with epic still active; stopping" >&2
    exit 1
  fi
  iteration=$((iteration + 1))

  raw_log="$log_dir/iter-$iteration.jsonl"
  echo
  echo "[ralph] iteration $iteration — epic $epic ($epic_title) | transcript: $raw_log"
  echo

  pipe_status=(0)
  claude "${claude_flags[@]}" "${extra_args[@]}" "$(harness_prompt "$iteration")" \
    | tee "$raw_log" | render_stream || pipe_status=("${PIPESTATUS[@]}")
  status="${pipe_status[0]}"

  if [ "$status" -ne 0 ]; then
    consecutive_failures=$((consecutive_failures + 1))
    echo "[ralph] claude exited $status (failure $consecutive_failures/3)" >&2
    if [ "$consecutive_failures" -ge 3 ]; then
      echo "[ralph] three consecutive failed runs; stopping" >&2
      exit 1
    fi
  else
    consecutive_failures=0
    # Anchor to line start so the agent quoting the instruction mid-sentence
    # cannot trip the brake by accident.
    if jq -r 'select(.type == "result") | .result // ""' "$raw_log" | grep -q '^RALPH-STOP:'; then
      echo
      echo "[ralph] agent pulled the emergency brake:" >&2
      jq -r 'select(.type == "result") | .result // ""' "$raw_log" | grep '^RALPH-STOP:' >&2
      exit 3
    fi
  fi

  # A breather between runs keeps ctrl-c easy and avoids hot-looping when a
  # run dies instantly.
  sleep 3
done
